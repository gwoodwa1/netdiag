{
  "renderer": "native",
  "recommended_renderer": "native",
  "layout": "rows",
  "output": "examples/regression/04-structured-link-labels.svg",
  "features": [
    {
      "feature": "custom_icons",
      "level": "strict",
      "reason": "at least one node selects a network icon"
    },
    {
      "feature": "endpoint_addresses",
      "level": "strict",
      "reason": "at least one endpoint has a CIDR address"
    },
    {
      "feature": "endpoint_sides",
      "level": "strict",
      "reason": "at least one endpoint has an explicit side"
    },
    {
      "feature": "middle_labels",
      "level": "strict",
      "reason": "at least one middle link label is required"
    },
    {
      "feature": "network_cards",
      "level": "strict",
      "reason": "network-specific device presentation is requested"
    },
    {
      "feature": "source_labels",
      "level": "strict",
      "reason": "source interface labels are required"
    },
    {
      "feature": "target_labels",
      "level": "strict",
      "reason": "target interface labels are required"
    }
  ],
  "warnings": []
}
